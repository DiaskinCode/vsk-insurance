<policy:savePolicyRequest xmlns:common="http://www.vsk.ru/schema/partners/common"
                          xmlns:model="http://www.vsk.ru/schema/partners/model"
                          xmlns:policy="http://www.vsk.ru/schema/partners/policy"
                          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <common:messageId>(message_id)</common:messageId>
    <common:bpId/>
    <common:sessionId>(session_id)</common:sessionId>
    <policy:policy>
        <model:product>
            <model:productCode>ACCIDENT</model:productCode>
        </model:product>
        <model:dateCreate>(date_create)T00:00:00+03:00</model:dateCreate>
        <model:dateStart>(date_start)T00:00:00+03:00</model:dateStart>
        <model:dateEnd>(date_end)T23:59:59+03:00
        </model:dateEnd>
        <model:policyObjects>
            <model:object xsi:type="model:IndividualsXT">
                <model:objectType>
                    <model:code>CONTRACTOR</model:code>
                </model:objectType>
                <model:contractorType>
                    <model:contractorTypeCode>INDIVIDUAL</model:contractorTypeCode>
                </model:contractorType>
                <model:firstName></model:firstName>
                <model:surname></model:surname>
                <model:secondName></model:secondName>
                <model:birthDate>(birth_insured_person)</model:birthDate>
                <model:gender>1</model:gender>
                <model:fullName>(fio_insured_person)</model:fullName>
            </model:object>
        (conditions)
        </model:policyObjects>
        <model:participant>
            <model:contractor xsi:type="model:IndividualsXT">
                <model:objectType>
                    <model:code>CONTRACTOR</model:code>
                </model:objectType>
                <model:contractorType>
                    <model:contractorTypeCode>INDIVIDUAL</model:contractorTypeCode>
                </model:contractorType>
                <model:contacts>
                    <model:contactType>
                        <model:contactTypeCode>PHONE</model:contactTypeCode>
                    </model:contactType>
                    <model:contact>(phone_policyholder)</model:contact>
                    <model:contactPerson></model:contactPerson>
                </model:contacts>
                <model:contacts>
                    <model:contactType>
                        <model:contactTypeCode>EMAIL</model:contactTypeCode>
                    </model:contactType>
                    <model:contact>(email_policyholder)</model:contact>
                    <model:contactPerson></model:contactPerson>
                </model:contacts>
                <model:firstName></model:firstName>
                <model:surname></model:surname>
                <model:secondName></model:secondName>
                <model:birthDate>(birth_policyholder)</model:birthDate>
                <model:gender>1</model:gender>
                <model:fullName>(fio_policyholder)</model:fullName>
            </model:contractor>
            <model:participantType>
                <model:participantTypeCode>INSURANT</model:participantTypeCode>
            </model:participantType>
        </model:participant>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>TYPE_OF_SPORT</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(type_of_sport)</model:classifierValue>
        </model:classifiers>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>IS_PROFESSIONAL</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(is_professional)</model:classifierValue>
        </model:classifiers>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>IS_SPORTTIME</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(is_sporttime)</model:classifierValue>
        </model:classifiers>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>PROMO_ACTION</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(promo)</model:classifierValue>
        </model:classifiers>
    </policy:policy>
    <policy:isQuotation>false</policy:isQuotation>
</policy:savePolicyRequest>