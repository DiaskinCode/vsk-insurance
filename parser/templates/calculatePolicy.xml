<policy:calculatePolicyRequest xmlns:common="http://www.vsk.ru/schema/partners/common"
                               xmlns:model="http://www.vsk.ru/schema/partners/model/calc"
                               xmlns:policy="http://www.vsk.ru/schema/partners/policy">
    <common:messageId>(message_id)</common:messageId>
    <policy:policy>
        <model:product>
            <model:productCode>ACCIDENT</model:productCode>
        </model:product>
        <model:dateStart>(date_start)T00:00:00+03:00</model:dateStart>
        <model:dateEnd>(date_end)T23:59:59+03:00</model:dateEnd>

        <model:policyObjects>
        (conditions)
        </model:policyObjects>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>TYPE_OF_SPORT</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(type_of_sport)</model:classifierValue>
        </model:classifiers>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>IS_PROFESSIONAL</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(is_professional)</model:classifierValue>
        </model:classifiers>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>IS_SPORTTIME</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(is_sporttime)</model:classifierValue>
        </model:classifiers>
        <model:classifiers>
            <model:classifierType>
                <model:classifierTypeCode>PROMO_ACTION</model:classifierTypeCode>
            </model:classifierType>
            <model:classifierValue>(promo)</model:classifierValue>
        </model:classifiers>
    </policy:policy>
</policy:calculatePolicyRequest>